# TokenGuard API Documentation
# Base URL: http://localhost:4000/api
#
# This is a token management system with 100 pre-generated tokens.
# Tokens are automatically released after 2 minutes of activity.

@base_url = http://localhost:4000/api
@user_id = {{$guid}}

###

# Register a token (activate for a user)
# Required: user_id (must be a valid UUID)
# Returns: token_id and user_id
# Uses FIFO (first available token by inserted_at)
# @name registerToken
POST {{base_url}}/tokens/register
content-type: application/json
accept: application/json

{
  "user_id": "{{user_id}}"
}

###

# List all tokens
# Returns: all tokens with their status
# @name listTokens
GET {{base_url}}/tokens
accept: application/json

###

# Extract first available token (all tokens start as available)
# @name firstToken
@token_id = {{listTokens.response.body.tokens[0].id}}

###

# Get specific token
# Returns: token details including active user (if active)
# @name getToken
GET {{base_url}}/tokens/{{token_id}}
accept: application/json

###

# Get token history
# Returns: usage history for a specific token
# @name getTokenHistory
GET {{base_url}}/tokens/{{token_id}}/history
accept: application/json

###

# Clear all active tokens
# Releases all active tokens back to available pool
# @name clearActiveTokens
DELETE {{base_url}}/tokens/active
accept: application/json
