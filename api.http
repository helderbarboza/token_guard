# TokenGuard API Documentation

@base_url = http://localhost:4000/api
@user_id = {{$guid}}
@token_id = {{registerToken.response.body.token_id}}

# @name registerToken
# Register a new token for a user
POST {{base_url}}/tokens/register
content-type: application/json
accept: application/json

{
  "user_id": "{{user_id}}"
}

###

# @name listTokens
# List all tokens for the user
GET {{base_url}}/tokens
accept: application/json

###

# @name getToken
# Get a specific token by ID
GET {{base_url}}/tokens/{{token_id}}
accept: application/json

###

# @name getTokenHistory
# Get the history of a specific token
GET {{base_url}}/tokens/{{token_id}}/history
accept: application/json

###

# @name clearActiveTokens
# Clear all active tokens for the user
DELETE {{base_url}}/tokens/active
accept: application/json